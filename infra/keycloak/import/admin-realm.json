{
  "realm": "admin-realm",
  "enabled": true,
  "displayName": "Credito Admin Realm",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "bruteForceProtected": true,
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyDigits": 6,
  "otpPolicyLookAheadWindow": 1,
  "otpPolicyPeriod": 30,
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": true,
      "priority": 10
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "ROLE_OPERATOR",
        "description": "Default operator access"
      },
      {
        "name": "ROLE_LOAN_REVIEWER",
        "description": "Loan review access"
      },
      {
        "name": "ROLE_MANAGER",
        "description": "Manager approval access"
      },
      {
        "name": "ROLE_BATCH_ADMIN",
        "description": "Batch operation access"
      }
    ]
  },
  "groups": [
    {
      "name": "operators",
      "path": "/operators",
      "realmRoles": [
        "ROLE_OPERATOR"
      ],
      "attributes": {
        "responsibility": [
          "Default operator access for admin console login and read-only operations"
        ]
      }
    },
    {
      "name": "loan-reviewers",
      "path": "/loan-reviewers",
      "realmRoles": [
        "ROLE_OPERATOR",
        "ROLE_LOAN_REVIEWER"
      ],
      "attributes": {
        "responsibility": [
          "Loan application review and underwriting workflow access"
        ]
      }
    },
    {
      "name": "managers",
      "path": "/managers",
      "realmRoles": [
        "ROLE_OPERATOR",
        "ROLE_MANAGER"
      ],
      "attributes": {
        "responsibility": [
          "Manager approval and elevated operational decision access"
        ]
      }
    },
    {
      "name": "batch-admins",
      "path": "/batch-admins",
      "realmRoles": [
        "ROLE_OPERATOR",
        "ROLE_BATCH_ADMIN"
      ],
      "attributes": {
        "responsibility": [
          "Batch job operation and administrative maintenance access"
        ]
      }
    }
  ],
  "clients": [
    {
      "clientId": "credito-admin-console",
      "name": "Credito Admin Console",
      "description": "Development client for operator login",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": true,
      "redirectUris": [
        "http://localhost:8080/admin/callback",
        "http://localhost:3000/admin/callback"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "http://localhost:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:8080/admin/logout/callback##http://localhost:3000/admin/logout/callback"
      },
      "protocolMappers": [
        {
          "name": "credito-admin-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "credito-admin-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        },
        {
          "name": "admin-realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ]
}
